# Project Automatron environment variables
# Copy this file to `.env` and fill in the values.

# LLM providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AI...

# Models
ARCHITECT_MODEL=gpt-5.3-codex
BUILDER_MODEL=gpt-5.3-codex
REVIEWER_MODEL=gpt-5.3-codex

# GitHub automation
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org-or-user
GITHUB_OWNER_TYPE=user
GITHUB_API_URL=https://api.github.com
GITHUB_REPO_VISIBILITY=private
GITHUB_ENVIRONMENT_NAME=production
GITHUB_ACTIONS_CI_WORKFLOW_NAME=CI
GITHUB_ACTIONS_DEPLOY_WORKFLOW_NAME=Deploy
GIT_AUTHOR_NAME=Automatron Bot
GIT_AUTHOR_EMAIL=automatron@example.local

# Database
SQLITE_DB_PATH=./data/automatron.db
CHECKPOINT_DB_PATH=./data/checkpoints.db

# Docker and workspace
GOLDEN_IMAGE=automatron/golden:latest
WORKSPACE_BASE_PATH=/var/automatron/workspaces
PORT_RANGE_START=7000
PORT_RANGE_END=7999

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Builder
BUILDER_CLINE_TIMEOUT=300

# Deploy over SSH
DEPLOY_SSH_KEY_PATH=
DEPLOY_SSH_OPTIONS=

# --- Auth (Google OAuth via Auth.js v5) ---
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Required for the web-ui (passed to NextAuth as AUTH_URL).
AUTH_URL=https://automatron.quitcode.com
# Google Cloud Console → OAuth 2.0 Client (Web). Redirect URI:
# https://automatron.quitcode.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Allowlist rules, comma-separated. Each rule is either:
#   - A full email (exact match): dev@quitcode.com
#   - A domain pattern starting with `@`: @quitcode.com (any email at that domain)
# Empty = gate delegated to Google Cloud Console (OAuth consent screen → Internal
# Workspace app, or Test users list).
AUTOMATRON_ALLOWED_EMAILS=@quitcode.com

# Public URL (also used by webhook auto-registration)
# AUTOMATRON_PUBLIC_URL=https://automatron.quitcode.com
