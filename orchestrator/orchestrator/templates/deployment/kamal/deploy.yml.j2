# Kamal deployment configuration — generated by Automatron.
# Do not edit by hand. Re-run "Generate artifacts" in Automatron to update.

service: {{ service_name }}
image: {{ image }}

servers:
  web:
    - {{ host }}

registry:
  server: {{ registry }}
  username: {{ registry_username }}
  password:
    - KAMAL_REGISTRY_PASSWORD

ssh:
  user: {{ ssh_user }}
  port: {{ ssh_port }}

proxy:
  ssl: true
  host: {{ domain }}
  app_port: {{ container_port }}
  healthcheck:
    path: {{ health_path }}
    interval: 3
    timeout: 5

env:
  clear:
    NODE_ENV: production
    PORT: "{{ container_port }}"
    HOSTNAME: "0.0.0.0"
{%- for key, value in clear_env.items() %}
    {{ key }}: {{ value | tojson }}
{%- endfor %}
{%- if secret_env_names %}
  secret:
{%- for name in secret_env_names %}
    - {{ name }}
{%- endfor %}
{%- endif %}
